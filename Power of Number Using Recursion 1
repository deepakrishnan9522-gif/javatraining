import java.util.Scanner;

public class Solution {
    public static void main(String[] args) {
        Scanner s = new Scanner(System.in);
        int a = s.nextInt();
        int b = s.nextInt();
        System.out.println(power(a, b));
    }

    static long power(int a, int b) {
        long res = 1;
        for (int i = 0; i < b; i++) {
            res *= a;
        }
        return res;
    }
}
