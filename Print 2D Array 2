import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner s = new Scanner(System.in);

        int R = s.nextInt();
        int C = s.nextInt();

        int[][] arr = new int[R][C];

        
        for (int i = 0; i < R; i++) {
            for (int j = 0; j < C; j++) {
                arr[i][j] = s.nextInt();
            }
        }

        
        for (int i = 0; i < R; i++) {
            for (int j = 0; j < C; j++) {
                System.out.print(arr[i][j]);
                if (j < C - 1) {
                    System.out.print(" ");
                }
            }
            System.out.println();
        }

       
    }

}
